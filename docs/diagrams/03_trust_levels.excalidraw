      "width": 700,
      "height": 35,
      "text": "Trust Levels and Policies",
      "fontSize": 28,
      "fontFamily": 3,
      "textAlign": "center",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent"
    },

    {
      "type": "rectangle",
      "version": 1,
      "id": "untrusted-row",
      "x": 40,
      "y": 60,
      "width": 820,
      "height": 90,
      "strokeColor": "#c92a2a",
      "backgroundColor": "#fff5f5",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "version": 1,
      "id": "untrusted-title",
      "x": 55,
      "y": 65,
      "width": 150,
      "height": 22,
      "text": "UNTRUSTED",
      "fontSize": 18,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#c92a2a"
    },
    {
      "type": "text",
      "version": 1,
      "id": "untrusted-who",
      "x": 220,
      "y": 67,
      "width": 550,
      "height": 18,
      "text": "Fork PRs, first-time contributors, triage, unknown actors",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#868e96"
    },
    {
      "type": "text",
      "version": 1,
      "id": "untrusted-policy",
      "x": 55,
      "y": 90,
      "width": 780,
      "height": 55,
      "text": "Allowed:  Read, Glob, Grep, WebFetch, WebSearch\nBlocked:  ALL Bash commands, Edit, Write, Git push, npm install\nThe agent can analyze code but cannot execute or change anything.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#495057"
    },

    {
      "type": "rectangle",
      "version": 1,
      "id": "contributor-row",
      "x": 40,
      "y": 160,
      "width": 820,
      "height": 110,
      "strokeColor": "#e8590c",
      "backgroundColor": "#fff9db",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "version": 1,
      "id": "contributor-title",
      "x": 55,
      "y": 165,
      "width": 180,
      "height": 22,
      "text": "CONTRIBUTOR",
      "fontSize": 18,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#e8590c"
    },
    {
      "type": "text",
      "version": 1,
      "id": "contributor-who",
      "x": 250,
      "y": 167,
      "width": 500,
      "height": 18,
      "text": "Read/write collaborators, maintain, bots (capped)",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#868e96"
    },
    {
      "type": "text",
      "version": 1,
      "id": "contributor-policy",
      "x": 55,
      "y": 192,
      "width": 780,
      "height": 70,
      "text": "Bash:  Allow list only (npm test, node, python, go test, cargo, make, jest, eslint)\nNetwork:  Isolated (no internet, loopback only)\nFilesystem:  Protected paths read-only (bwrap)\nBlocked:  Editing .github/workflows/, CLAUDE.md, .cursorrules, .claude/\nCan run tests and read code, but cannot exfiltrate or modify CI/CD config.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#495057"
    },

    {
      "type": "rectangle",
      "version": 1,
      "id": "trusted-row",
      "x": 40,
      "y": 280,
      "width": 820,
      "height": 70,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "#ebfbee",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "version": 1,
      "id": "trusted-title",
      "x": 55,
      "y": 285,
      "width": 120,
      "height": 22,
      "text": "TRUSTED",
      "fontSize": 18,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#2b8a3e"
    },
    {
      "type": "text",
      "version": 1,
      "id": "trusted-who",
      "x": 185,
      "y": 287,
      "width": 550,
      "height": 18,
      "text": "Repo admins only (bots with admin are capped at contributor)",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#868e96"
    },
    {
      "type": "text",
      "version": 1,
      "id": "trusted-policy",
      "x": 55,
      "y": 310,
      "width": 780,
      "height": 35,
      "text": "Allowed:  All tools, no restrictions, no sandboxing\nInput scanning runs as warning only. Full trust. These are the repo owners.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#495057"
    }
  ],
  "appState": {
    "viewBackgroundColor": "#ffffff",
